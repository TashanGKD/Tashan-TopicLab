# TopicLab - Production Deploy Environment
# Copy to .env.deploy, fill in, then paste full content into GitHub Secrets → DEPLOY_ENV
# cp .env.deploy.example .env.deploy

# -----------------------------------------------------------------------------
# Docker volume mounts (persist workspace & libs)
# -----------------------------------------------------------------------------
WORKSPACE_PATH=./workspace
LIBS_PATH=./backend/libs

# -----------------------------------------------------------------------------
# Frontend base path (must match host nginx location)
# -----------------------------------------------------------------------------
# world.tashan.chat 根路径部署（deploy.yml 生成 location /api/）: VITE_BASE_PATH=/
# topic-lab 子路径部署: VITE_BASE_PATH=/topic-lab/
VITE_BASE_PATH=/
# /info/source embeds the WorldWeave dashboard through this same-origin path.
VITE_WORLDWEAVE_FRONTEND_URL=/worldweave/

# -----------------------------------------------------------------------------
# Ports (must match nginx config)
# -----------------------------------------------------------------------------
FRONTEND_PORT=3000
BACKEND_PORT=8000
TOPICLAB_BACKEND_PORT=8001

# -----------------------------------------------------------------------------
# topiclab-backend (auth) - Required for production
# -----------------------------------------------------------------------------
# Optional when topiclab-backend is not on the same docker-compose network:
# RESONNET_BASE_URL=http://127.0.0.1:8000
# In docker-compose, topiclab-backend uses the internal backend service URL
# http://backend:8000. Do not reuse BACKEND_PORT for container-to-container calls.
# source-feed 话题标题/摘要生成使用 AI_GENERATION_BASE_URL + AI_GENERATION_API_KEY，
# 模型固定为 qwen3.5-plus
# 灵感共创线索的大模型预诊断/脱敏改写统一使用下面这个完整 chat-completions 接口。
INSPIRATION_LLM_CHAT_COMPLETIONS_URL=
INSPIRATION_LLM_API_KEY=
INSPIRATION_LLM_MODEL=
INSPIRATION_LLM_TIMEOUT_SECONDS=45
# SOURCE_FEED_AUTOMATION_ENABLED=true
# SOURCE_FEED_AUTOMATION_INTERVAL_SECONDS=1800
# SOURCE_FEED_AUTOMATION_FETCH_LIMIT=20
# SOURCE_FEED_AUTOMATION_SELECT_COUNT=1
# SOURCE_FEED_AUTOMATION_START_DISCUSSION=true
# SOURCE_FEED_AUTOMATION_DISCUSSION_MAX_TURNS=6000
DATABASE_URL=postgresql://user:pass@host:5432/topiclab
# DB_POOL_SIZE=5
# DB_POOL_MAX_OVERFLOW=10
PGSSLMODE=disable
# Optional read-only/shared Agent4S article database from tashanhomepage.
# Configure this when TopicLab should read the live Agent4S WeChat article list
# from the same database as tashanhomepage instead of falling back to DATABASE_URL.
TASHAN_HOMEPAGE_DATABASE_URL=postgresql://user:pass@host:5432/tashanhomepage
TASHAN_HOMEPAGE_PGSSLMODE=disable
TASHAN_HOMEPAGE_DB_CONNECT_TIMEOUT=5
JWT_SECRET=your-secret-key-change-in-production
ADMIN_PANEL_PASSWORD=change-me
# 用于 /qr/* 页面上传更新二维码图片；页面通过 ?key=... 传入，后端校验后转 WebP 写入 site_assets。
SITE_ASSET_UPLOAD_KEY=change-me
# ADMIN_OBSERVABILITY_TIMEZONE=Asia/Shanghai
# ADMIN_OBSERVABILITY_EVENT_LIMIT=5000

# SMS (SMSBao). Omit for dev mode (codes in UI/logs).
# SMSBAO_USERNAME=
# SMSBAO_PASSWORD=

# -----------------------------------------------------------------------------
# Arcade evaluator service
# -----------------------------------------------------------------------------
# Required when ClawArcade local_subprocess cabinets should receive automatic
# reviewer replies after TopicLab deploys.
ARCADE_EVALUATOR_SECRET_KEY=
ARCADE_BASE_URL=https://world.tashan.chat
ARCADE_MAX_CONCURRENT=3
ARCADE_REVIEWER_BASE_URL=http://topiclab-backend:8000
ARCADE_REVIEWER_DEPLOYMENT_PROFILE=cpu
ARCADE_REVIEWER_EXCLUDE_SOURCES=cabinets/turing-teahouse/101-CIFAR
# ARCADE_REVIEWER_SKIP_SMOKE=0

# -----------------------------------------------------------------------------
# Resonnet backend (use production API keys)
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=
ANTHROPIC_MODEL=
AI_GENERATION_BASE_URL=
AI_GENERATION_API_KEY=
AI_GENERATION_MODEL=
SCNET_BASE_URL=https://api.scnet.cn/api/llm/v1
SCNET_API_KEY=
# SkillHub bilingual search and Critic evaluation use one dedicated key. The
# endpoint, protocol, and GLM 5.2 model already have application defaults.
skillhub_scnet_api_key=
AUTH_SERVICE_BASE_URL=http://topiclab-backend:8000
INFORMATION_COLLECTION_BASE_URL=http://ic.nexus.tashan.ac.cn
# Independent same-host WorldWeave service. Its container port remains 5000;
# Set WORLDWEAVE_HOST_PORT=3020 in WorldWeave's own DEPLOY_ENV so it does not
# collide with other host services.
# Replace both values with the stable HTTPS origin when it runs on another host.
WORLDWEAVE_BASE_URL=http://host.docker.internal:3020
WORLDWEAVE_UPSTREAM=http://host.docker.internal:3020
# The initial Qwen3-Embedding-8B package contains 2386 documents.
TOPICLINK_ZVEC_MIN_DOC_COUNT=2386
AUTH_MODE=jwt
AUTH_REQUIRED=true
ACCOUNT_SYNC_ENABLED=true
PROFILE_HELPER_MAX_TOOL_ITERATIONS=40

# OpenClaw ask-agent bridge. Optional; when all four values are configured,
# topiclab-backend includes ask_agent in bootstrap/renew responses.
# OPENCLAW_ASK_AGENT_URL=https://example.com/stream_run
# OPENCLAW_ASK_AGENT_TOKEN=
# OPENCLAW_ASK_PROJECT_ID=
# OPENCLAW_ASK_SESSION_ID=
